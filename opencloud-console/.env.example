# ══════════════════════════════════════════════════════════════
# OpenCloud Console — 环境变量配置示例
#
# 使用说明：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 修改 .env 中的敏感值（密码、密钥等）
#   3. .env 已加入 .gitignore，不会提交到版本库
#
# Docker 启动：docker-compose --env-file .env up -d
# ══════════════════════════════════════════════════════════════

# ─── Spring Profile ───────────────────────────────────────────
# 可选：dev | test | prod
SPRING_PROFILES_ACTIVE=dev

# ─── 数据库（PostgreSQL）───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=opencloud
DB_USER=opencloud
DB_PASS=opencloud123

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ─── JWT（必须修改为强随机密钥，≥256 bits）─────────────────────
# 生成建议：openssl rand -hex 64
JWT_SECRET=opencloud-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256-CHANGE-ME
JWT_ACCESS_TTL=7200      # Access Token 有效期（秒），默认 2h
JWT_REFRESH_TTL=604800   # Refresh Token 有效期（秒），默认 7d

# ─── AES-256 加密密钥（用于 AK/SK、通知渠道配置加密存储）──────
# 生成建议：openssl rand -hex 32（须恰好 32 个 ASCII 字符）
ENCRYPT_KEY=opencloud-aes-key-must-be-32-chars!

# ─── CORS（生产环境必须指定明确域名，禁止使用 *）─────────────
# 多个域名用逗号分隔：https://console.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# ─── 邮件通知（SMTP）────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USER=alert@example.com
MAIL_PASS=your-smtp-password

# ─── Prometheus ───────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090

# ─── Grafana ─────────────────────────────────────────────────
GRAFANA_URL=http://grafana:3000
# 生成方式：Grafana → Administration → Service Accounts → 创建 Token
GRAFANA_TOKEN=

# ─── OpenStack（可选，不使用 OpenStack 可留空）────────────────
OS_AUTH_URL=http://controller:5000/v3
OS_USERNAME=admin
OS_PASSWORD=
OS_PROJECT=admin
OS_DOMAIN=Default

# ─── Ceph（可选）─────────────────────────────────────────────
CEPH_MGR_URL=http://ceph-mgr:8003
CEPH_RGW_URL=http://ceph-rgw:7480
CEPH_ACCESS_KEY=
CEPH_SECRET_KEY=

# ─── Kubernetes（可选）───────────────────────────────────────
K8S_CONFIG=~/.kube/config
K8S_NAMESPACE=default
