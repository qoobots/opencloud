<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="60 seconds">

  <!-- ─── 属性定义 ──────────────────────────────────────────── -->
  <property name="LOG_DIR"     value="/logs/opencloud"/>
  <property name="APP_NAME"    value="opencloud-console"/>
  <property name="MAX_HISTORY" value="30"/>
  <property name="MAX_SIZE"    value="100MB"/>
  <property name="TOTAL_SIZE"  value="5GB"/>

  <!-- 日志格式：时间 线程 级别 [traceId] 类名 - 消息 -->
  <property name="LOG_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId}] %logger{36} - %msg%n"/>

  <!-- ─── 开发环境：彩色控制台输出 ──────────────────────────── -->
  <springProfile name="dev,test">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) [%cyan(%X{traceId})] %logger{36} - %msg%n</pattern>
        <charset>UTF-8</charset>
      </encoder>
    </appender>

    <root level="DEBUG">
      <appender-ref ref="CONSOLE"/>
    </root>

    <!-- 降低框架噪音日志 -->
    <logger name="org.springframework"              level="INFO"/>
    <logger name="org.springframework.security"     level="DEBUG"/>
    <logger name="com.baomidou.mybatisplus"         level="INFO"/>
    <logger name="org.hibernate.validator"          level="WARN"/>
    <logger name="io.lettuce"                       level="WARN"/>
    <logger name="com.zaxxer.hikari"                level="INFO"/>
  </springProfile>

  <!-- ─── 生产环境：文件滚动输出 ────────────────────────────── -->
  <springProfile name="prod">

    <!-- INFO+ 日志：按日期 + 大小滚动，保留 30 天，总上限 5GB -->
    <appender name="FILE_INFO" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${LOG_DIR}/${APP_NAME}.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
        <fileNamePattern>${LOG_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
        <maxFileSize>${MAX_SIZE}</maxFileSize>
        <maxHistory>${MAX_HISTORY}</maxHistory>
        <totalSizeCap>${TOTAL_SIZE}</totalSizeCap>
      </rollingPolicy>
      <encoder>
        <pattern>${LOG_PATTERN}</pattern>
        <charset>UTF-8</charset>
      </encoder>
    </appender>

    <!-- ERROR 日志：单独归档，保留 90 天 -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
        <level>ERROR</level>
      </filter>
      <file>${LOG_DIR}/${APP_NAME}-error.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${LOG_DIR}/${APP_NAME}-error.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
        <maxHistory>90</maxHistory>
      </rollingPolicy>
      <encoder>
        <pattern>${LOG_PATTERN}</pattern>
        <charset>UTF-8</charset>
      </encoder>
    </appender>

    <!-- 异步写入 INFO 日志（避免 I/O 阻塞请求线程） -->
    <appender name="ASYNC_INFO" class="ch.qos.logback.classic.AsyncAppender">
      <queueSize>512</queueSize>
      <discardingThreshold>0</discardingThreshold>  <!-- 队列满时不丢弃 -->
      <appender-ref ref="FILE_INFO"/>
    </appender>

    <root level="INFO">
      <appender-ref ref="ASYNC_INFO"/>
      <appender-ref ref="FILE_ERROR"/>
    </root>

    <!-- 降低框架噪音日志 -->
    <logger name="org.springframework"          level="WARN"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="com.baomidou.mybatisplus"     level="WARN"/>
    <logger name="io.lettuce"                   level="WARN"/>
    <logger name="com.zaxxer.hikari"            level="WARN"/>
  </springProfile>

</configuration>
