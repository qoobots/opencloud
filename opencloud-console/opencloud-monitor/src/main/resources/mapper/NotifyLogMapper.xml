<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qoobot.opencloud.monitor.notify.log.mapper.NotifyLogMapper">

    <!-- 结果映射 -->
    <resultMap id="NotifyLogRM" type="com.qoobot.opencloud.monitor.notify.log.domain.entity.MonitorNotifyLog">
        <id     column="id"              property="id"/>
        <result column="tenant_id"       property="tenantId"/>
        <result column="alert_record_id" property="alertRecordId"/>
        <result column="channel_id"      property="channelId"/>
        <result column="channel_name"    property="channelName"/>
        <result column="channel_type"    property="channelType"/>
        <result column="is_test"         property="isTest"/>
        <result column="status"          property="status"/>
        <result column="error_msg"       property="errorMsg"/>
        <result column="retry_count"     property="retryCount"/>
        <result column="sent_at"         property="sentAt"/>
    </resultMap>

</mapper>
